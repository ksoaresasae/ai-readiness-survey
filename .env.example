# Copy this file to .env.local and fill in the values. .env.local is gitignored.

# Supabase project (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — server-side only (used by /api/submit and /api/responses)
SUPABASE_SERVICE_ROLE_KEY=

# Admin dashboard password (sent as the x-admin-key header to /api/responses)
ADMIN_PASSWORD=

# Anthropic API key (used by /api/analyze to generate the respondent snapshot)
ANTHROPIC_API_KEY=
